#!/bin/sh

if [ "$1" = "cleanup" ]; then
	script_type=cleanup
	INTERFACE="$2"
	CLEANUP_FORCE="$3"
fi

[ -z "$script_type" ] && {
	logger -t "openvpn(proto)" -p daemon.warn "hotplug: variable 'script_type' not found"
	exit
}

[ -z "$INTERFACE" ] && {
	logger -t "openvpn(proto)" -p daemon.warn "hotplug: variable 'INTERFACE' not found"
	exit
}

. /lib/functions.sh
. /lib/netifd/netifd-proto.sh
. /usr/share/libubox/jshn.sh

SERVER_ROUTE_DIR="/var/run/openvpn-routefix"

# OpenVPN exports these script variables in lowercase; keep uppercase copies
# for internal state handling.
DAEMON_START_TIME="${daemon_start_time:-0}"
DAEMON_PID="${daemon_pid:-}"

mask2prefix() {
	local mask="$1"
	local n=0
	local IFS=.
	for o in $mask; do
		case $o in
			255) n=$((n+8)) ;;
			254) n=$((n+7)) ;;
			252) n=$((n+6)) ;;
			248) n=$((n+5)) ;;
			240) n=$((n+4)) ;;
			224) n=$((n+3)) ;;
			192) n=$((n+2)) ;;
			128) n=$((n+1)) ;;
			0)   break     ;;
			*)   break     ;;
		esac
	done
	echo "$n"
}

parse_cidr6() {
	local val="$1"
	local def_plen="$2"
	local addr="${val%/*}"
	local plen="${val#*/}"
	[ "$addr" = "$plen" ] && plen="$def_plen"
	echo "$addr $plen"
}

server_route_state_file() {
	printf '%s/%s.%s\n' "$SERVER_ROUTE_DIR" "${INTERFACE:-openvpn}" "$1"
}

route_dev_for_gateway() {
	local family="$1"
	local gateway="$2"
	local output gateway_dev

	[ -n "$gateway" ] || return 0

	output="$(ip "-$family" route get "$gateway" 2>/dev/null)" || return 0
	gateway_dev="$(printf '%s\n' "$output" | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -n 1)"

	printf '%s\n' "$gateway_dev"
}

remove_server_route() {
	local family="$1"
	local prefix="$2"
	local target="$3"
	local gateway="$4"
	local gateway_dev="$5"

	[ -n "$target" ] || return 0
	[ -n "$gateway" ] || return 0

	if [ -n "$gateway_dev" ]; then
		ip "-$family" route del "$target/$prefix" via "$gateway" dev "$gateway_dev" >/dev/null 2>&1 && return 0
	fi

	ip "-$family" route del "$target/$prefix" via "$gateway" >/dev/null 2>&1 && return 0
	ip "-$family" route del "$target/$prefix" >/dev/null 2>&1

	return 0
}

routefix_is_uint() {
	case "$1" in
		''|*[!0-9]*)
			return 1
		;;
	esac

	return 0
}

server_route_start_time() {
	printf '%s\n' "$DAEMON_START_TIME"
}

server_route_pid() {
	printf '%s\n' "$DAEMON_PID"
}

# Avoid overwriting route state written by a newer OpenVPN reconnect if an
# older hook runs late.
server_route_state_is_newer() {
	local state_start="$1"
	local state_pid="$2"
	local current_start current_pid

	current_start="$(server_route_start_time)"
	current_pid="$(server_route_pid)"

	routefix_is_uint "$state_start" || return 1
	routefix_is_uint "$current_start" || return 1
	[ "$state_start" -gt 0 ] || return 1
	[ "$current_start" -gt 0 ] || return 1

	[ "$state_start" -gt "$current_start" ] && return 0

	if [ "$state_start" = "$current_start" ] &&
		routefix_is_uint "$state_pid" &&
		routefix_is_uint "$current_pid"; then
		[ "$state_pid" -gt "$current_pid" ] && return 0
	fi

	return 1
}

# Only remove saved routes from the OpenVPN process which created them. This
# prevents stale down/route-pre-down hooks from deleting a newer reconnect's
# route state.
server_route_state_owned_by_current() {
	local state_start="$1"
	local state_pid="$2"
	local current_start current_pid

	current_start="$(server_route_start_time)"
	current_pid="$(server_route_pid)"

	if routefix_is_uint "$state_start" && routefix_is_uint "$current_start" && [ "$state_start" -gt 0 ] && [ "$current_start" -gt 0 ]; then
		[ "$state_start" = "$current_start" ] || return 1
	fi

	if [ -n "$state_pid" ] && [ -n "$current_pid" ]; then
		[ "$state_pid" = "$current_pid" ] || return 1
	fi

	return 0
}

write_server_route_state() {
	local state_file="$1"
	local target="$2"
	local gateway="$3"
	local gateway_dev="$4"

	(
		json_init
		json_add_string target "$target"
		json_add_string gateway "$gateway"
		json_add_string gateway_dev "$gateway_dev"
		json_add_string daemon_start_time "$(server_route_start_time)"
		json_add_string daemon_pid "$(server_route_pid)"
		json_dump
	) > "$state_file"
}

read_server_route_state() {
	local state_file="$1"

	route_state_target=
	route_state_gateway=
	route_state_gateway_dev=
	route_state_start=
	route_state_pid=

	json_load_file "$state_file" 2>/dev/null || return 1
	json_get_var route_state_target target
	json_get_var route_state_gateway gateway
	json_get_var route_state_gateway_dev gateway_dev
	json_get_var route_state_start daemon_start_time
	json_get_var route_state_pid daemon_pid

	[ -n "$route_state_target" ] || return 1
	[ -n "$route_state_gateway" ] || return 1

	return 0
}

install_server_route() {
	local family="$1"
	local prefix="$2"
	local target="$3"
	local gateway="$4"
	local gateway_dev state_file

	# OpenVPN resolves the pre-tunnel gateway before --route-noexec stops it
	# from installing routes. Keep a host route to the VPN peer via that
	# gateway so a pushed default route does not loop transport packets into
	# the tunnel itself.
	[ -n "$target" ] || return 0
	[ -n "$gateway" ] || return 0
	[ "$gateway" != "0.0.0.0" ] || return 0
	[ "$gateway" != "::" ] || return 0

	mkdir -p "$SERVER_ROUTE_DIR"
	state_file="$(server_route_state_file "ipv$family")"

	if [ -r "$state_file" ]; then
		read_server_route_state "$state_file" || rm -f "$state_file"
		server_route_state_is_newer "$route_state_start" "$route_state_pid" && return 0
		if [ "$route_state_target" != "$target" ] || [ "$route_state_gateway" != "$gateway" ]; then
			remove_server_route \
				"$family" "$prefix" "$route_state_target" \
				"$route_state_gateway" "$route_state_gateway_dev"
		fi
	fi

	gateway_dev="$(route_dev_for_gateway "$family" "$gateway")"

	if [ -n "$gateway_dev" ] && [ "$gateway_dev" != "$dev" ]; then
		if ip "-$family" route replace "$target/$prefix" via "$gateway" dev "$gateway_dev" >/dev/null 2>&1; then
			write_server_route_state "$state_file" "$target" "$gateway" "$gateway_dev"
		fi
		return 0
	fi

	if [ "$gateway_dev" = "$dev" ]; then
		return 0
	fi

	# If the gateway lookup did not return a usable device, still try to
	# install the host route via the pre-tunnel gateway and let the kernel
	# resolve the egress device.
	if ip "-$family" route replace "$target/$prefix" via "$gateway" >/dev/null 2>&1; then
		write_server_route_state "$state_file" "$target" "$gateway" ""
	fi

	return 0
}

redirect_gateway_ipv4_enabled() {
	[ "$route_redirect_gateway_ipv4" = "1" ] && return 0
	[ "$route_redirect_gateway_ipv4" = "2" ] && return 0
	[ "$redirect_gateway" = "1" ] && return 0

	return 1
}

redirect_gateway_ipv6_enabled() {
	[ "$route_redirect_gateway_ipv6" = "1" ] && return 0
	[ "$route_redirect_gateway_ipv6" = "2" ] && return 0

	return 1
}

ipv4_default_route_requested() {
	local i net mask

	redirect_gateway_ipv4_enabled && return 0

	i=0
	while :; do
		i=$((i+1))
		eval "net=\$route_network_$i mask=\$route_netmask_$i"
		[ -z "$net" ] && break
		[ -z "$mask" ] && continue

		[ "$net" = "0.0.0.0" ] && [ "$mask" = "0.0.0.0" ] && return 0
		if [ "$mask" = "128.0.0.0" ]; then
			[ "$net" = "0.0.0.0" ] && return 0
			[ "$net" = "128.0.0.0" ] && return 0
		fi
	done

	return 1
}

ipv6_default_route_requested() {
	local i net

	redirect_gateway_ipv6_enabled && return 0

	i=0
	while :; do
		i=$((i+1))
		eval "net=\$route_ipv6_network_$i"
		[ -z "$net" ] && break

		case "$net" in
			::|::/0|::/1|::/3|2000::/4|3000::/4|fc00::/7)
				return 0
			;;
		esac
	done

	return 1
}

install_needed_ipv4_server_route() {
	ipv4_default_route_requested && install_server_route 4 32 "$trusted_ip" "$route_net_gateway"
}

install_needed_ipv6_server_route() {
	ipv6_default_route_requested && install_server_route 6 128 "$trusted_ip6" "$route_ipv6_gateway"
}

add_vpn_default_routes() {
	local gateway="$1"

	[ -n "$gateway" ] || return 1

	proto_add_ipv4_route "0.0.0.0" 1 "$gateway"
	proto_add_ipv4_route "128.0.0.0" 1 "$gateway"

	return 0
}

add_openvpn_ipv4_routes() {
	local i net mask gw plen added=1 vpn_default_added=1

	if redirect_gateway_ipv4_enabled && add_vpn_default_routes "$route_vpn_gateway"; then
		added=0
		vpn_default_added=0
	fi

	i=0
	while :; do
		i=$((i+1))
		eval "net=\$route_network_$i mask=\$route_netmask_$i gw=\$route_gateway_$i"
		[ -z "$net" ] && break
		[ -z "$mask" ] && continue
		if [ "$net" = "0.0.0.0" ] && [ "$mask" = "0.0.0.0" ]; then
			if redirect_gateway_ipv4_enabled; then
				if add_vpn_default_routes "${gw:-$route_vpn_gateway}"; then
					added=0
					vpn_default_added=0
				fi
				continue
			fi
		fi
		if [ "$vpn_default_added" = 0 ] && [ "$mask" = "128.0.0.0" ]; then
			[ "$net" = "0.0.0.0" ] && continue
			[ "$net" = "128.0.0.0" ] && continue
		fi

		plen=$(mask2prefix "$mask")
		proto_add_ipv4_route "$net" "$plen" "$gw"
		added=0
	done

	return "$added"
}

add_openvpn_ipv6_routes() {
	local i net gw v6net v6plen added=1

	if [ -n "$ifconfig_ipv6_remote" ]; then
		proto_add_ipv6_route "::" 0 "$ifconfig_ipv6_remote"
		added=0
	fi

	i=0
	while :; do
		i=$((i+1))
		eval "net=\$route_ipv6_network_$i gw=\$route_ipv6_gateway_$i"
		[ -z "$net" ] && break

		read -r v6net v6plen <<-EOF
			$(parse_cidr6 "$net" 128)
		EOF
		proto_add_ipv6_route "$v6net" "$v6plen" "$gw"
		added=0
	done

	return "$added"
}

remove_saved_server_route() {
	local family="$1"
	local prefix="$2"
	local suffix="$3"
	local force="$4"
	local state_file

	state_file="$(server_route_state_file "$suffix")"
	[ -r "$state_file" ] || return 0

	read_server_route_state "$state_file" || {
		rm -f "$state_file"
		return 0
	}

	if [ "$force" != "1" ]; then
		server_route_state_owned_by_current \
			"$route_state_start" "$route_state_pid" || return 0
	fi

	remove_server_route \
		"$family" "$prefix" "$route_state_target" \
		"$route_state_gateway" "$route_state_gateway_dev"
	rm -f "$state_file"
}

remove_saved_server_routes() {
	local force="$1"

	remove_saved_server_route 4 32 ipv4 "$force"
	remove_saved_server_route 6 128 ipv6 "$force"
}

case "$script_type" in
	up)
		install_needed_ipv4_server_route
		[ "$IPV6" = "1" ] && install_needed_ipv6_server_route

		proto_init_update "$dev" 1

		[ -n "$ifconfig_local" ] && proto_add_ipv4_address "$ifconfig_local" "${ifconfig_netmask:-255.255.255.255}"

		add_openvpn_ipv4_routes

		if [ "$IPV6" = "1" ]; then
			if [ -n "$ifconfig_ipv6_local" ]; then
				read -r v6addr v6plen <<-EOF
					$(parse_cidr6 "$ifconfig_ipv6_local" "${ifconfig_ipv6_netbits:-128}")
				EOF
				proto_add_ipv6_address "$v6addr" "$v6plen"
			fi

			add_openvpn_ipv6_routes
		fi

		[ -n "$tun_mtu" ] && json_add_int mtu "$tun_mtu"

		i=0
		while :; do
			i=$((i+1))
			eval "option=\$foreign_option_$i"
			[ -z "$option" ] && break

			set -- $option
			[ "$1" != "dhcp-option" ] && continue

			case "$2" in
				DNS)           proto_add_dns_server "$3" ;;
				DOMAIN*)       proto_add_dns_search "$3" ;; # Matches DOMAIN and DOMAIN-SEARCH
			esac
		done

		proto_send_update "$INTERFACE"
	;;

	route-up)
		install_needed_ipv4_server_route
		[ "$IPV6" = "1" ] && install_needed_ipv6_server_route

		route_update=1
		proto_init_update "$dev" 1
		proto_set_keep 1
		add_openvpn_ipv4_routes && route_update=0
		if [ "$IPV6" = "1" ]; then
			add_openvpn_ipv6_routes && route_update=0
		fi
		[ "$route_update" = 0 ] && proto_send_update "$INTERFACE"
	;;

	down)
		remove_saved_server_routes
		proto_init_update "$dev" 0
		proto_send_update "$INTERFACE"
	;;

	route-pre-down)
		remove_saved_server_routes
	;;

	cleanup)
		remove_saved_server_routes "$CLEANUP_FORCE"
		exit 0
	;;
esac

ACTION="$script_type"
INSTANCE="$INTERFACE"

export ACTION="$ACTION"
export INSTANCE="$INSTANCE"
exec /sbin/hotplug-call openvpn "$@"
