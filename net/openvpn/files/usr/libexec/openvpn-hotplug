#!/bin/sh

if [ "$1" = "cleanup" ]; then
	script_type=cleanup
	INTERFACE="$2"
fi

[ -z "$script_type" ] && {
	logger -t "openvpn(proto)" -p daemon.warn "hotplug: variable 'script_type' not found"
	exit
}

[ -z "$INTERFACE" ] && {
	logger -t "openvpn(proto)" -p daemon.warn "hotplug: variable 'INTERFACE' not found"
	exit
}

. /lib/functions.sh
. /lib/netifd/netifd-proto.sh

SERVER_ROUTE_DIR="/var/run/openvpn-routefix"

mask2prefix() {
	local mask="$1"
	local n=0
	local IFS=.
	for o in $mask; do
		case $o in
			255) n=$((n+8)) ;;
			254) n=$((n+7)) ;;
			252) n=$((n+6)) ;;
			248) n=$((n+5)) ;;
			240) n=$((n+4)) ;;
			224) n=$((n+3)) ;;
			192) n=$((n+2)) ;;
			128) n=$((n+1)) ;;
			0)   break     ;;
			*)   break     ;;
		esac
	done
	echo "$n"
}

parse_cidr6() {
	local val="$1"
	local def_plen="$2"
	local addr="${val%/*}"
	local plen="${val#*/}"
	[ "$addr" = "$plen" ] && plen="$def_plen"
	echo "$addr $plen"
}

server_route_state_file() {
	printf '%s/%s.%s\n' "$SERVER_ROUTE_DIR" "${INTERFACE:-openvpn}" "$1"
}

route_dev_for_gateway() {
	local family="$1"
	local gateway="$2"
	local output gateway_dev

	[ -n "$gateway" ] || return 0

	output="$(ip "-$family" route get "$gateway" 2>/dev/null)" || return 0
	gateway_dev="$(printf '%s\n' "$output" | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -n 1)"

	printf '%s\n' "$gateway_dev"
}

remove_server_route() {
	local family="$1"
	local prefix="$2"
	local target="$3"
	local gateway="$4"
	local gateway_dev="$5"

	[ -n "$target" ] || return 0
	[ -n "$gateway" ] || return 0

	if [ -n "$gateway_dev" ]; then
		ip "-$family" route del "$target/$prefix" via "$gateway" dev "$gateway_dev" >/dev/null 2>&1 && return 0
	fi

	ip "-$family" route del "$target/$prefix" via "$gateway" >/dev/null 2>&1 && return 0
	ip "-$family" route del "$target/$prefix" >/dev/null 2>&1

	return 0
}

install_server_route() {
	local family="$1"
	local prefix="$2"
	local target="$3"
	local gateway="$4"
	local gateway_dev state_file old_target old_gateway old_gateway_dev

	[ -n "$target" ] || return 0
	[ -n "$gateway" ] || return 0
	[ "$gateway" != "0.0.0.0" ] || return 0
	[ "$gateway" != "::" ] || return 0

	mkdir -p "$SERVER_ROUTE_DIR"
	state_file="$(server_route_state_file "ipv$family")"

	if [ -r "$state_file" ]; then
		read -r old_target old_gateway old_gateway_dev < "$state_file"
		if [ "$old_target" != "$target" ] || [ "$old_gateway" != "$gateway" ]; then
			remove_server_route "$family" "$prefix" "$old_target" "$old_gateway" "$old_gateway_dev"
		fi
	fi

	gateway_dev="$(route_dev_for_gateway "$family" "$gateway")"

	if [ -n "$gateway_dev" ] && [ "$gateway_dev" != "$dev" ]; then
		if ip "-$family" route replace "$target/$prefix" via "$gateway" dev "$gateway_dev" >/dev/null 2>&1; then
			printf '%s %s %s\n' "$target" "$gateway" "$gateway_dev" > "$state_file"
		fi
		return 0
	fi

	if [ "$gateway_dev" = "$dev" ]; then
		return 0
	fi

	if ip "-$family" route replace "$target/$prefix" via "$gateway" >/dev/null 2>&1; then
		printf '%s %s %s\n' "$target" "$gateway" "" > "$state_file"
	fi

	return 0
}

add_vpn_default_routes() {
	local gateway="$1"

	[ -n "$gateway" ] || return 1

	proto_add_ipv4_route "0.0.0.0" 1 "$gateway"
	proto_add_ipv4_route "128.0.0.0" 1 "$gateway"

	return 0
}

openvpn_dev() {
	if [ -n "$dev" ]; then
		printf '%s\n' "$dev"
		return 0
	fi

	if command -v ifstatus >/dev/null 2>&1 && command -v jsonfilter >/dev/null 2>&1; then
		ifstatus "$INTERFACE" 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null && return 0
		ifstatus "$INTERFACE" 2>/dev/null | jsonfilter -e '@.device' 2>/dev/null && return 0
	fi

	return 1
}

remove_vpn_default_routes() {
	local vpn_dev

	vpn_dev="$(openvpn_dev 2>/dev/null)"
	[ -n "$vpn_dev" ] || return 0

	ip -4 route del default dev "$vpn_dev" >/dev/null 2>&1
	ip -4 route del 0.0.0.0/1 dev "$vpn_dev" >/dev/null 2>&1
	ip -4 route del 128.0.0.0/1 dev "$vpn_dev" >/dev/null 2>&1
}

add_openvpn_ipv4_routes() {
	local i net mask gw plen added=1 vpn_default_added=1

	if add_vpn_default_routes "$route_vpn_gateway"; then
		added=0
		vpn_default_added=0
	fi

	i=0
	while :; do
		i=$((i+1))
		eval "net=\$route_network_$i mask=\$route_netmask_$i gw=\$route_gateway_$i"
		[ -z "$net" ] && break
		[ -z "$mask" ] && continue
		if [ "$net" = "0.0.0.0" ] && [ "$mask" = "0.0.0.0" ]; then
			if add_vpn_default_routes "${gw:-$route_vpn_gateway}"; then
				added=0
				vpn_default_added=0
			fi
			continue
		fi
		if [ "$vpn_default_added" = 0 ] && [ "$mask" = "128.0.0.0" ]; then
			[ "$net" = "0.0.0.0" ] && continue
			[ "$net" = "128.0.0.0" ] && continue
		fi

		plen=$(mask2prefix "$mask")
		proto_add_ipv4_route "$net" "$plen" "$gw"
		added=0
	done

	return "$added"
}

add_openvpn_ipv6_routes() {
	local i net gw v6net v6plen added=1

	if [ -n "$ifconfig_ipv6_remote" ]; then
		proto_add_ipv6_route "::" 0 "$ifconfig_ipv6_remote"
		added=0
	fi

	i=0
	while :; do
		i=$((i+1))
		eval "net=\$route_ipv6_network_$i gw=\$route_ipv6_gateway_$i"
		[ -z "$net" ] && break

		read -r v6net v6plen <<-EOF
			$(parse_cidr6 "$net" 128)
		EOF
		proto_add_ipv6_route "$v6net" "$v6plen" "$gw"
		added=0
	done

	return "$added"
}

remove_saved_server_routes() {
	local state_file target gateway gateway_dev

	state_file="$(server_route_state_file ipv4)"
	if [ -r "$state_file" ]; then
		read -r target gateway gateway_dev < "$state_file"
		remove_server_route 4 32 "$target" "$gateway" "$gateway_dev"
		rm -f "$state_file"
	fi

	state_file="$(server_route_state_file ipv6)"
	if [ -r "$state_file" ]; then
		read -r target gateway gateway_dev < "$state_file"
		remove_server_route 6 128 "$target" "$gateway" "$gateway_dev"
		rm -f "$state_file"
	fi
}

case "$script_type" in
	up)
		proto_init_update "$dev" 1

		[ -n "$ifconfig_local" ] && proto_add_ipv4_address "$ifconfig_local" "${ifconfig_netmask:-255.255.255.255}"

		install_server_route 4 32 "$trusted_ip" "$route_net_gateway"

		add_openvpn_ipv4_routes

		if [ "$IPV6" = "1" ]; then
			if [ -n "$ifconfig_ipv6_local" ]; then
				read -r v6addr v6plen <<-EOF
					$(parse_cidr6 "$ifconfig_ipv6_local" "${ifconfig_ipv6_netbits:-128}")
				EOF
				proto_add_ipv6_address "$v6addr" "$v6plen"
			fi

			install_server_route 6 128 "$trusted_ip6" "$route_ipv6_gateway"

			add_openvpn_ipv6_routes
		fi

		[ -n "$tun_mtu" ] && json_add_int mtu "$tun_mtu"

		i=0
		while :; do
			i=$((i+1))
			eval "option=\$foreign_option_$i"
			[ -z "$option" ] && break

			set -- $option
			[ "$1" != "dhcp-option" ] && continue

			case "$2" in
				DNS)           proto_add_dns_server "$3" ;;
				DOMAIN*)       proto_add_dns_search "$3" ;; # Matches DOMAIN and DOMAIN-SEARCH
			esac
		done

		proto_send_update "$INTERFACE"
	;;

	route-up)
		route_update=1
		proto_init_update "$dev" 1
		proto_set_keep 1
		install_server_route 4 32 "$trusted_ip" "$route_net_gateway"
		add_openvpn_ipv4_routes && route_update=0
		if [ "$IPV6" = "1" ]; then
			install_server_route 6 128 "$trusted_ip6" "$route_ipv6_gateway"
			add_openvpn_ipv6_routes && route_update=0
		fi
		[ "$route_update" = 0 ] && proto_send_update "$INTERFACE"
	;;

	down)
		remove_vpn_default_routes
		remove_saved_server_routes
		proto_init_update "$dev" 0
		proto_send_update "$INTERFACE"
	;;

	route-pre-down)
		remove_vpn_default_routes
		remove_saved_server_routes
	;;

	cleanup)
		remove_vpn_default_routes
		remove_saved_server_routes
		exit 0
	;;
esac

ACTION="$script_type"
INSTANCE="$INTERFACE"

export ACTION="$ACTION"
export INSTANCE="$INSTANCE"
exec /sbin/hotplug-call openvpn "$@"
