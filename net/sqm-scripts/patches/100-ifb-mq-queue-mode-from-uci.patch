diff --git a/src/functions.sh b/src/functions.sh
index a0b3f59..05d0fea 100644
--- a/src/functions.sh
+++ b/src/functions.sh
@@ -354,13 +354,35 @@ create_ifb() {
     local name
     local args
     local num_procs
+    local queue_mode
+    local num_queues
     name=$1
     args=
 
     num_procs=$(grep -c processor /proc/cpuinfo)
 
     if [ "$USE_MQ" -eq "1" ] && [ "$num_procs" -gt 1 ]; then
-        args="numtxqueues $num_procs"
+        queue_mode="${IFB_MQ_QUEUES_MODE:-half}"
+
+        case "$queue_mode" in
+            1|single)
+                num_queues=1
+                ;;
+            half|'')
+                num_queues=$(( (num_procs + 1) / 2 ))
+                ;;
+            all|cpu|cores)
+                num_queues=$num_procs
+                ;;
+            *)
+                sqm_warn "Unknown IFB_MQ_QUEUES_MODE '${queue_mode}', falling back to half"
+                num_queues=$(( (num_procs + 1) / 2 ))
+                ;;
+        esac
+
+        [ "$num_queues" -lt 1 ] && num_queues=1
+        [ "$num_queues" -gt "$num_procs" ] && num_queues=$num_procs
+        [ "$num_queues" -gt 1 ] && args="numtxqueues $num_queues"
     fi
     $IP link add name $name $args type ifb
 }
